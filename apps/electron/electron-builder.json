{
  "appId": "com.xenolexia.puzzle",
  "productName": "Xenolexia",
  "directories": {
    "output": "release"
  },
  "files": ["dist/**/*", "dist-electron/**/*"],
  "extraMetadata": {
    "main": "dist-electron/main.js"
  },
  "win": {
    "target": ["nsis"],
    "icon": null
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.games"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Game"
  }
}
